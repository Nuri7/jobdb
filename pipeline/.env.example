# Supabase (jobdb project)
SUPABASE_URL=https://khsaaiguqwtxtkvzqbrm.supabase.co
# Service role key: required for writes (refresh/resolve). Anon key is enough for --dry-run.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# LLM (OpenAI-compatible chat/completions endpoint) — tier-4 extraction + resolver disambiguation only.
# Default is Anthropic's OpenAI-compatible endpoint; any OpenAI-compatible provider works.
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_CALLS=500

# Worker tuning
COMPANY_CONCURRENCY=10
ROBOTS_RESPECT=true
